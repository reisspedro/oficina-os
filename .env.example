# Porta em que o servidor Express vai escutar (padrão 3000)
PORT=3000

# Chave secreta usada para assinar tokens JWT — obrigatória em produção, use string aleatória de 64+ chars
JWT_SECRET=

# Caminho do arquivo do banco SQLite (em produção, aponte pra disco persistente)
DB_PATH=./data/oficina.db

# Ambiente de execução — use "production" em deploys reais
NODE_ENV=development
